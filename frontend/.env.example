# Backend API
REACT_APP_API_BASE_URL=http://localhost:5050
REACT_APP_DEFAULT_LOGIN_USERNAME=operator

# Flight provider selection: auto | opensky | adsbx | mock
REACT_APP_FLIGHT_PROVIDER=auto

# OpenSky feed
REACT_APP_FLIGHTS_API_URL=https://opensky-network.org/api/states/all
REACT_APP_OPENSKY_USERNAME=
REACT_APP_OPENSKY_PASSWORD=

# ADS-B Exchange (or compatible endpoint)
REACT_APP_ADSB_EXCHANGE_URL=
REACT_APP_ADSB_EXCHANGE_KEY=

# Intel overlays
REACT_APP_SATELLITE_API_URL=
REACT_APP_SATELLITE_API_KEY=
REACT_APP_SEISMIC_API_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
REACT_APP_CCTV_API_URL=
REACT_APP_WINDY_WEBCAMS_KEY=
REACT_APP_STREET_TRAFFIC_API_URL=
REACT_APP_STREET_TRAFFIC_KEY=

# Alert routing
REACT_APP_ALERT_WEBHOOK_URL=

# Terrain mode: analytic | google-3d-tiles
REACT_APP_TERRAIN_MODE=analytic
REACT_APP_GOOGLE_3D_TILES_API_KEY=
REACT_APP_GOOGLE_3D_TILES_URL=

# Optional override for political/country border GeoJSON
REACT_APP_POLITICAL_MAP_URL=
